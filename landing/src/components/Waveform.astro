---
// Waveform — vertical ink bars of varying height, the visual shorthand for
// audio. Mirrors src/components/WaveformVisualizer.tsx: deterministic
// sine+noise shape, bars left of `progress` turn lime.
interface Props {
  bars?: number;
  progress?: number; // 0..1 — fraction of bars painted lime
  height?: number; // px
  class?: string;
}
const { bars = 40, progress = 0, height = 56, class: cls = '' } = Astro.props;

// Same shape function as the app's WaveformVisualizer.
const heights = Array.from({ length: bars }, (_, i) => {
  const n = i / bars;
  const base = Math.sin(n * Math.PI) * 0.7 + 0.2;
  const noise = (Math.sin(i * 12.9898) * 43758.5453) % 1;
  return Math.min(1, Math.max(0.12, base + Math.abs(noise) * 0.4));
});
const progressIndex = Math.floor(bars * progress);
---

<div class={`wave ${cls}`} style={`--wave-h:${height}px`} aria-hidden="true">
  {
    heights.map((h, i) => (
      <span
        class={i < progressIndex ? 'wave__bar wave__bar--on' : 'wave__bar'}
        style={`height:${Math.max(4, h * height)}px`}
      />
    ))
  }
</div>

<style>
  .wave {
    display: flex;
    align-items: center;
    gap: 3px;
    height: var(--wave-h);
    width: 100%;
  }
  .wave__bar {
    flex: 1;
    background: var(--ink);
    border-radius: var(--radius-pill);
    min-width: 2px;
  }
  .wave__bar--on {
    background: var(--signal);
  }
</style>
