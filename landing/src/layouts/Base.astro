---
// Base HTML shell: fonts, meta, global tokens. Every page wraps in this.
import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Signal — Say it out loud.',
  description = 'A voice-first social network. 30-second voice notes, six reactions, a live global feed. No text. Just voices.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/assets/signal_graphic.png" />
    <meta name="theme-color" content="#ccff00" />

    <!-- Google Fonts: the exact three families from the style guide. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
